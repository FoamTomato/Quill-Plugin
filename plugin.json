{
  "name": "quill",
  "version": "0.2.0",
  "description": "Quill 4-agent orchestration + PRD production for any project. Install once, use everywhere.",
  "author": "foamtomato",
  "homepage": "https://github.com/foamtomato/quill-plugin",
  "license": "MIT",
  "commands": [
    "commands/quill.md",
    "commands/quill-update-skills.md"
  ],
  "hooks": "hooks/hooks.json",
  "metadata": {
    "skill_bundle": {
      "default_source": "https://xiaohang.site/skills/bundle.tar.gz",
